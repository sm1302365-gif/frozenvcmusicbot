# ---------------------------------------------------------------------------
# KwaiCut configuration. Copy to `.env` and adjust. All values are optional;
# sensible defaults are applied for local development.
# ---------------------------------------------------------------------------

# General
KWAICUT_ENV=development                 # development | staging | production
KWAICUT_DEBUG=true

# Database. SQLite by default; point at PostgreSQL in production.
# e.g. postgresql+psycopg2://user:pass@localhost:5432/kwaicut
KWAICUT_DATABASE_URL=sqlite:///./kwaicut.db

# Auth / JWT. CHANGE THIS in any non-local environment.
KWAICUT_SECRET_KEY=change-me-in-production
KWAICUT_ACCESS_TOKEN_EXPIRE_MINUTES=60
KWAICUT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Storage roots for media assets and rendered exports.
KWAICUT_MEDIA_ROOT=./var/media
KWAICUT_EXPORT_ROOT=./var/exports

# External binaries.
KWAICUT_FFMPEG_BINARY=ffmpeg
KWAICUT_FFPROBE_BINARY=ffprobe

# AI providers. Leave empty to use the built-in local/stub providers.
KWAICUT_WHISPER_MODEL=base
KWAICUT_OPENAI_API_KEY=
KWAICUT_AI_DEVICE=auto                   # auto | cpu | cuda
